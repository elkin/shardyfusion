{
  "pythonVersion": "3.11",
  "typeCheckingMode": "standard",
  "include": ["../shardyfusion"],
  "exclude": [
    "../shardyfusion/writer/dask",
    "../shardyfusion/writer/python",
    "../shardyfusion/writer/ray",
    "../shardyfusion/cli",
    "../shardyfusion/reader/async_reader.py"
  ],
  "extraPaths": [".."],
  "reportArgumentType": "error",
  "reportMissingParameterType": "error",
  "reportUnsupportedDunderAll": false
}
