{
  "pythonVersion": "3.11",
  "typeCheckingMode": "standard",
  "include": [
    "../shardyfusion"
  ],
  "exclude": [
    "../shardyfusion/writer/python",
    "../shardyfusion/writer/spark",
    "../shardyfusion/writer/ray",
    "../shardyfusion/cli",
    "../shardyfusion/reader/async_reader.py",
    "../shardyfusion/metrics/prometheus.py",
    "../shardyfusion/metrics/otel.py"
  ],
  "extraPaths": [
    ".."
  ],
  "reportArgumentType": "error",
  "reportMissingParameterType": "error",
  "reportUnsupportedDunderAll": false
}
